  <button class="img-modal-close" onclick="closeImgModal()">✕</button>
  <img id="imgModalSrc" src="" alt="">
</div>



<script>
// ===== STATE =====
let currentUser = null;
let mqttClient = null;
let selectedImageBase64 = null;
let viewingUser = null;
let allUsers = {};
let allPosts = [];
let allNotifications = [];

// ===== LOCALSTORAGE HELPERS =====
function saveUsers() { localStorage.setItem('vibe_users', JSON.stringify(allUsers)); }
function savePosts() { localStorage.setItem('vibe_posts', JSON.stringify(allPosts)); }
function saveNotifications() { localStorage.setItem('vibe_notifs_' + currentUser.username, JSON.stringify(allNotifications)); }

function loadAll() {
  allUsers = JSON.parse(localStorage.getItem('vibe_users') || '{}');
  allPosts = JSON.parse(localStorage.getItem('vibe_posts') || '[]');
}

function loadNotifications() {
  if (!currentUser) return;
  allNotifications = JSON.parse(localStorage.getItem('vibe_notifs_' + currentUser.username) || '[]');
}

// ===== AUTH =====
function switchAuthTab(tab) {
  document.querySelectorAll('.auth-tab').forEach((t,i) => {
    t.classList.toggle('active', (i === 0 && tab==='login') || (i===1 && tab==='register'));
  });
  document.getElementById('loginForm').style.display = tab==='login' ? 'block' : 'none';
  document.getElementById('registerForm').style.display = tab==='register' ? 'block' : 'none';
  document.getElementById('loginError').textContent = '';
  document.getElementById('registerError').textContent = '';
}

function doRegister() {
  const name = document.getElementById('regName').value.trim();
  const username = document.getElementById('regUser').value.trim().toLowerCase().replace(/[^a-z0-9_]/g,'');
  const bio = document.getElementById('regBio').value.trim();
  const pass = document.getElementById('regPass').value;
  const pass2 = document.getElementById('regPass2').value;
  const err = document.getElementById('registerError');

  if (!name) { err.textContent = 'Введи имя'; return; }
  if (!username) { err.textContent = 'Введи username (только латиница, цифры, _)'; return; }
  if (!pass) { err.textContent = 'Придумай пароль'; return; }
  if (pass !== pass2) { err.textContent = 'Пароли не совпадают'; return; }
  if (allUsers[username]) { err.textContent = 'Этот username занят'; return; }
  if (pass.length < 4) { err.textContent = 'Пароль слишком короткий'; return; }

  allUsers[username] = {
    name, username, bio,
    password: btoa(pass),
    avatar: null,
    followers: [],
    following: [],
    createdAt: Date.now()
  };
  saveUsers();
  err.style.color = '#22c55e';
  err.textContent = 'Аккаунт создан! Войди ↑';
  switchAuthTab('login');
  document.getElementById('loginUser').value = username;
}

function doLogin() {
  const username = document.getElementById('loginUser').value.trim().toLowerCase();
  const pass = document.getElementById('loginPass').value;
  const err = document.getElementById('loginError');

  if (!username || !pass) { err.textContent = 'Заполни все поля'; return; }
  const user = allUsers[username];
  if (!user) { err.textContent = 'Пользователь не найден'; return; }
  if (atob(user.password) !== pass) { err.textContent = 'Неверный пароль'; return; }

  currentUser = user;
  sessionStorage.setItem('vibe_session', username);
  startApp();
}

function doLogout() {
  if (!confirm('Выйти из аккаунта?')) return;
  currentUser = null;
  sessionStorage.removeItem('vibe_session');
  if (mqttClient) mqttClient.end();
  document.getElementById('appScreen').style.display = 'none';
  document.getElementById('authScreen').style.display = 'flex';
  closeSidebar();
}

// ===== MQTT =====
function initMQTT() {
  const clientId = 'vibe_' + currentUser.username + '_' + Math.random().toString(36).substr(2,6);
  try {
    mqttClient = mqtt.connect('wss://broker.hivemq.com:8884/mqtt', {
      clientId,
      clean: true,
      reconnectPeriod: 3000,
      connectTimeout: 8000
    });

    mqttClient.on('connect', () => {
      setConnStatus(true);
      mqttClient.subscribe('vibe/posts');
      mqttClient.subscribe('vibe/likes');
      mqttClient.subscribe('vibe/comments');
      mqttClient.subscribe('vibe/follows');
      mqttClient.subscribe('vibe/profiles');
    });

    mqttClient.on('disconnect', () => setConnStatus(false));
    mqttClient.on('error', () => setConnStatus(false));
    mqttClient.on('offline', () => setConnStatus(false));

    mqttClient.on('message', (topic, message) => {
      try {
        const data = JSON.parse(message.toString());
        if (data.sender === currentUser.username) return; // skip own broadcasts
        handleMQTT(topic, data);
      } catch(e) {}
    });
  } catch(e) {
    setConnStatus(false);
  }
}

function setConnStatus(connected) {}

function publish(topic, data) {
  if (mqttClient && mqttClient.connected) {
    mqttClient.publish(topic, JSON.stringify({ ...data, sender: currentUser.username }));
  }
}

function handleMQTT(topic, data) {
  if (topic === 'vibe/posts') {
    // New post from someone
    if (!allPosts.find(p => p.id === data.post.id)) {
      allPosts.unshift(data.post);
      savePosts();
      renderFeed();
    }
  } else if (topic === 'vibe/likes') {
    const post = allPosts.find(p => p.id === data.postId);
    if (post) {
      if (data.action === 'like') {
        if (!post.likes) post.likes = [];
        if (!post.likes.includes(data.username)) post.likes.push(data.username);
        // Notification for post owner
        if (post.author === currentUser.username) {
          addNotification(`❤️ <strong>${data.username}</strong> лайкнул твой пост`);
        }
      } else {
        post.likes = (post.likes||[]).filter(u => u !== data.username);
      }
      savePosts();
      renderFeed();
    }
  } else if (topic === 'vibe/comments') {
    const post = allPosts.find(p => p.id === data.postId);
    if (post) {
      if (!post.comments) post.comments = [];
      post.comments.push(data.comment);
      if (post.author === currentUser.username) {
        addNotification(`💬 <strong>${data.comment.author}</strong> прокомментировал твой пост`);
      }
      savePosts();
      renderFeed();
    }
  } else if (topic === 'vibe/follows') {
    const user = allUsers[data.target];
    if (user) {
      if (data.action === 'follow') {
        if (!user.followers.includes(data.username)) user.followers.push(data.username);
        if (data.target === currentUser.username) {
          addNotification(`👤 <strong>${data.username}</strong> подписался на тебя`);
          currentUser.followers = user.followers;
        }
      } else {
        user.followers = user.followers.filter(u => u !== data.username);
        if (data.target === currentUser.username) currentUser.followers = user.followers;
      }
      saveUsers();
    }
  } else if (topic === 'vibe/profiles') {
    if (allUsers[data.username]) {
      allUsers[data.username].name = data.name;
      allUsers[data.username].bio = data.bio;
      if (data.avatar) allUsers[data.username].avatar = data.avatar;
      saveUsers();
      renderFeed();
    }
  }
}

function addNotification(html) {
  const notif = { html, time: Date.now(), id: Date.now() + Math.random() };
  allNotifications.unshift(notif);
  if (allNotifications.length > 50) allNotifications.pop();
  saveNotifications();
  renderNotifications();
  document.getElementById('notifBadge').classList.add('show');
}

// ===== APP START =====
function startApp() {
  loadNotifications();
  document.getElementById('authScreen').style.display = 'none';
  document.getElementById('appScreen').style.display = 'block';
  updateTopbarAvatar();
  renderFeed();
  renderMyProfile();
  renderNotifications();
  initMQTT();
}

function updateTopbarAvatar() {
  const el = document.getElementById('topbarAvatar');
  if (currentUser.avatar) {
    el.innerHTML = `<img src="${currentUser.avatar}" alt="">`;
  } else {
    el.textContent = (currentUser.name || currentUser.username)[0].toUpperCase();
    el.style.background = 'var(--blue-light)';
    el.style.color = 'var(--blue)';
    el.style.fontSize = '14px';
    el.style.fontWeight = '800';
    el.style.display = 'flex';
    el.style.alignItems = 'center';
    el.style.justifyContent = 'center';
  }
}

// ===== SIDEBAR =====
function toggleSidebar() {
  const s = document.getElementById('sidebar');
  const o = document.getElementById('sidebarOverlay');
  const b = document.getElementById('burgerBtn');
  const open = s.classList.contains('open');
  s.classList.toggle('open', !open);
  o.classList.toggle('show', !open);
  b.classList.toggle('active', !open);
}

function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('show');
  document.getElementById('burgerBtn').classList.remove('active');
}

// ===== PANELS =====
function showPanel(name) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));

  if (name === 'notifications') {
    document.getElementById('notifBadge').classList.remove('show');
  }
  if (name === 'myprofile') {
    renderMyProfile();
  }
}

function showMyProfile() {
  renderMyProfile();
  showPanel('myprofile');
}

// ===== POSTS =====
function generateId() {
  return Date.now().toString(36) + Math.random().toString(36).substr(2,5);
}

function handleImageSelect(e) {
  const file = e.target.files[0];
  if (!file) return;
  if (file.size > 3 * 1024 * 1024) {
    alert('Изображение слишком большое (максимум 3MB)');
    return;
  }
  const reader = new FileReader();
  reader.onload = (ev) => {
    selectedImageBase64 = ev.target.result;
    document.getElementById('imgPreview').src = selectedImageBase64;
    document.getElementById('imgPreviewWrap').classList.add('show');
  };
  reader.readAsDataURL(file);
}

function removeImage() {
  selectedImageBase64 = null;
  document.getElementById('imgPreviewWrap').classList.remove('show');
  document.getElementById('imgPreview').src = '';
  document.getElementById('imgFileInput').value = '';
}

function publishPost() {
  const text = document.getElementById('postTextInput').value.trim();
  if (!text && !selectedImageBase64) return;

  const post = {
    id: generateId(),
    author: currentUser.username,
    authorName: currentUser.name,
    authorAvatar: currentUser.avatar,
    text,
    image: selectedImageBase64,
    likes: [],
    comments: [],
    time: Date.now()
  };

  allPosts.unshift(post);
  savePosts();

  publish('vibe/posts', { post });

  document.getElementById('postTextInput').value = '';
  removeImage();
  renderFeed();
}

function renderFeed() {
  const container = document.getElementById('postsContainer');
  const me = currentUser;

  // Update create post avatar
  const cpAvatar = document.getElementById('createPostAvatar');
  renderAvatarEl(cpAvatar, me.name, me.avatar, 40);

  if (allPosts.length === 0) {
    container.innerHTML = `<div class="empty-state"><div class="emoji">✨</div><p>Пока постов нет. Будь первым!</p></div>`;
    return;
  }

  container.innerHTML = allPosts.map(post => buildPostHTML(post)).join('');
}

function buildPostHTML(post) {
  const likedByMe = (post.likes||[]).includes(currentUser.username);
  const likesCount = (post.likes||[]).length;
  const commCount = (post.comments||[]).length;
  const timeStr = formatTime(post.time);
  const authorUser = allUsers[post.author] || {};
  const avatarHtml = buildAvatarHTML(post.authorName || post.author, post.authorAvatar || authorUser.avatar, 40);
  const imageHtml = post.image ? `<img class="post-image" src="${post.image}" alt="" onclick="openImgModal('${escapeAttr(post.image)}')" loading="lazy">` : '';
  const commentsHtml = (post.comments||[]).map(c => {
    const cu = allUsers[c.author] || {};
    const cavHtml = buildAvatarHTML(c.authorName || c.author, c.authorAvatar || cu.avatar, 30);
    return `<div class="comment-item">
      <div class="comment-avatar">${cavHtml}</div>
      <div class="comment-bubble">
        <strong onclick="openUserProfile('${escapeAttr(c.author)}')">${escapeHtml(c.authorName || c.author)}</strong>
        <p>${escapeHtml(c.text)}</p>
      </div>
    </div>`;
  }).join('');

  return `<div class="post-card" id="post-${post.id}">
    <div class="post-header">
      <div class="post-avatar" onclick="openUserProfile('${escapeAttr(post.author)}')">${avatarHtml}</div>
      <div class="post-meta">
        <div class="post-username" onclick="openUserProfile('${escapeAttr(post.author)}')">${escapeHtml(post.authorName || post.author)} <span style="color:var(--text-soft);font-weight:600;font-size:12px;">@${escapeHtml(post.author)}</span></div>
        <div class="post-time">${timeStr}</div>
      </div>
    </div>
    <div class="post-body">
      ${post.text ? `<div class="post-text">${escapeHtml(post.text)}</div>` : ''}
      ${imageHtml}
    </div>
    <div class="post-actions">
      <button class="action-btn ${likedByMe ? 'liked' : ''}" onclick="toggleLike('${post.id}')">
        <span class="icon">${likedByMe ? '❤️' : '🤍'}</span>
        <span>${likesCount > 0 ? likesCount : ''}</span>
      </button>
      <button class="action-btn" onclick="toggleComments('${post.id}')">
        <span class="icon">💬</span>
        <span>${commCount > 0 ? commCount : ''}</span>
      </button>
    </div>
    <div class="comments-section" id="comments-${post.id}">
      ${commentsHtml}
      <div class="comment-input-row">
        <input class="comment-input" id="commentInput-${post.id}" placeholder="Написать комментарий..." onkeydown="if(event.key==='Enter')sendComment('${post.id}')">
        <button class="comment-send-btn" onclick="sendComment('${post.id}')">➤</button>
      </div>
    </div>
  </div>`;
}

function buildAvatarHTML(name, avatar, size) {
  if (avatar) {
    return `<img src="${avatar}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%">`;
  }
  return (name || '?')[0].toUpperCase();
}

function renderAvatarEl(el, name, avatar, size) {
  if (avatar) {
    el.innerHTML = `<img src="${avatar}" alt="">`;
    el.style.background = '';
  } else {
    el.textContent = (name || '?')[0].toUpperCase();
    el.style.background = 'var(--blue-light)';
    el.style.color = 'var(--blue)';
    el.style.fontWeight = '800';
    el.style.fontSize = size * 0.35 + 'px';
  }
}

function toggleLike(postId) {
  const post = allPosts.find(p => p.id === postId);
  if (!post) return;
  if (!post.likes) post.likes = [];
  const idx = post.likes.indexOf(currentUser.username);
  let action;
  if (idx === -1) {
    post.likes.push(currentUser.username);
    action = 'like';
    // Notify post author (local)
    if (post.author !== currentUser.username) {
      const ownerNotifs = JSON.parse(localStorage.getItem('vibe_notifs_' + post.author) || '[]');
      ownerNotifs.unshift({ html: `❤️ <strong>${currentUser.username}</strong> лайкнул твой пост`, time: Date.now(), id: Date.now() });
      localStorage.setItem('vibe_notifs_' + post.author, JSON.stringify(ownerNotifs));
    }
  } else {
    post.likes.splice(idx, 1);
    action = 'unlike';
  }
  savePosts();
  publish('vibe/likes', { postId, username: currentUser.username, action });
  renderFeed();
}

function toggleComments(postId) {
  const section = document.getElementById('comments-' + postId);
  if (section) section.classList.toggle('show');
}

function sendComment(postId) {
  const input = document.getElementById('commentInput-' + postId);
  if (!input) return;
  const text = input.value.trim();
  if (!text) return;

  const post = allPosts.find(p => p.id === postId);
  if (!post) return;

  const comment = {
    id: generateId(),
    author: currentUser.username,
    authorName: currentUser.name,
    authorAvatar: currentUser.avatar,
    text,
    time: Date.now()
  };

  if (!post.comments) post.comments = [];
  post.comments.push(comment);

  // Notify post owner (local)
  if (post.author !== currentUser.username) {
    const ownerNotifs = JSON.parse(localStorage.getItem('vibe_notifs_' + post.author) || '[]');
    ownerNotifs.unshift({ html: `💬 <strong>${currentUser.username}</strong> прокомментировал твой пост`, time: Date.now(), id: Date.now() });
    localStorage.setItem('vibe_notifs_' + post.author, JSON.stringify(ownerNotifs));
  }

  savePosts();
  publish('vibe/comments', { postId, comment });
  input.value = '';
  renderFeed();
  // Re-show comments section
  setTimeout(() => {
    const section = document.getElementById('comments-' + postId);
    if (section) section.classList.add('show');
  }, 50);
}

// ===== USER PROFILE =====
function openUserProfile(username) {
  if (username === currentUser.username) {
    showMyProfile();
    return;
  }
  viewingUser = allUsers[username];
  if (!viewingUser) return;

  showPanel('userprofile');
  renderUserProfile(username);
}

function renderUserProfile(username) {
  const user = allUsers[username] || {};
  const userPosts = allPosts.filter(p => p.author === username);
  const totalLikes = userPosts.reduce((sum, p) => sum + (p.likes||[]).length, 0);
  const isFollowing = (currentUser.following||[]).includes(username);

  document.getElementById('profileViewName').textContent = user.name || username;
  document.getElementById('profileViewHandle').textContent = '@' + username;
  document.getElementById('profileViewBio').textContent = user.bio || '';
  document.getElementById('profilePostCount').textContent = userPosts.length;
  document.getElementById('profileLikeCount').textContent = totalLikes;
  document.getElementById('profileFollowerCount').textContent = (user.followers||[]).length;

  const bigAv = document.getElementById('profileBigAvatar');
  renderAvatarEl(bigAv, user.name || username, user.avatar, 88);

  const followBtn = document.getElementById('followBtn');
  followBtn.textContent = isFollowing ? '✓ Подписан' : '+ Подписаться';
  followBtn.className = 'follow-btn' + (isFollowing ? ' following' : '');

  viewingUser = user;
  viewingUser.username = username;

  const userPostsEl = document.getElementById('userPostsContainer');
  if (userPosts.length === 0) {
    userPostsEl.innerHTML = `<div class="empty-state"><div class="emoji">📝</div><p>Постов пока нет</p></div>`;
  } else {
    userPostsEl.innerHTML = userPosts.map(p => buildPostHTML(p)).join('');
  }
}

function toggleFollow() {
  if (!viewingUser) return;
  const username = viewingUser.username;
  const user = allUsers[username];
  if (!user) return;

  if (!currentUser.following) currentUser.following = [];
  if (!user.followers) user.followers = [];

  const idx = currentUser.following.indexOf(username);
  let action;
  if (idx === -1) {
    currentUser.following.push(username);
    if (!user.followers.includes(currentUser.username)) user.followers.push(currentUser.username);
    action = 'follow';
    // Notify (local)
    const targetNotifs = JSON.parse(localStorage.getItem('vibe_notifs_' + username) || '[]');
    targetNotifs.unshift({ html: `👤 <strong>${currentUser.username}</strong> подписался на тебя`, time: Date.now(), id: Date.now() });
    localStorage.setItem('vibe_notifs_' + username, JSON.stringify(targetNotifs));
  } else {
    currentUser.following.splice(idx, 1);
    user.followers = user.followers.filter(u => u !== currentUser.username);
    action = 'unfollow';
  }

  allUsers[currentUser.username] = { ...allUsers[currentUser.username], following: currentUser.following };
  saveUsers();
  publish('vibe/follows', { username: currentUser.username, target: username, action });
  renderUserProfile(username);
}

// ===== MY PROFILE =====
function renderMyProfile() {
  if (!currentUser) return;
  document.getElementById('myProfileName').textContent = currentUser.name;
  document.getElementById('myProfileHandle').textContent = '@' + currentUser.username;
  document.getElementById('editName').value = currentUser.name || '';
  document.getElementById('editBio').value = currentUser.bio || '';

  const avEl = document.getElementById('myAvatarEdit');
  if (currentUser.avatar) {
    avEl.innerHTML = `<img src="${currentUser.avatar}" alt=""><div class="my-avatar-overlay">📷</div>`;
  } else {
    avEl.innerHTML = `<span style="font-size:22px;font-weight:800;color:var(--blue)">${(currentUser.name||'?')[0].toUpperCase()}</span><div class="my-avatar-overlay">📷</div>`;
  }

  const myPosts = allPosts.filter(p => p.author === currentUser.username);
  const container = document.getElementById('myPostsContainer');
  if (myPosts.length === 0) {
    container.innerHTML = `<div class="empty-state"><div class="emoji">📝</div><p>У тебя пока нет постов</p></div>`;
  } else {
    container.innerHTML = myPosts.map(p => buildPostHTML(p)).join('');
  }
}

function saveProfile() {
  const name = document.getElementById('editName').value.trim();
  const bio = document.getElementById('editBio').value.trim();
  if (!name) { alert('Имя не может быть пустым'); return; }

  currentUser.name = name;
  currentUser.bio = bio;
  allUsers[currentUser.username].name = name;
  allUsers[currentUser.username].bio = bio;
  saveUsers();

  publish('vibe/profiles', { username: currentUser.username, name, bio, avatar: currentUser.avatar });

  updateTopbarAvatar();
  renderMyProfile();
  renderFeed();
  alert('Профиль сохранён! ✓');
}

function handleAvatarUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  if (file.size > 2 * 1024 * 1024) { alert('Аватарка слишком большая (макс 2MB)'); return; }
  const reader = new FileReader();
  reader.onload = (ev) => {
    currentUser.avatar = ev.target.result;
    allUsers[currentUser.username].avatar = ev.target.result;
    // Update all posts by this user
    allPosts.forEach(p => { if (p.author === currentUser.username) p.authorAvatar = ev.target.result; });
    saveUsers();
    savePosts();
    publish('vibe/profiles', { username: currentUser.username, name: currentUser.name, bio: currentUser.bio, avatar: ev.target.result });
    updateTopbarAvatar();
    renderMyProfile();
    renderFeed();
  };
  reader.readAsDataURL(file);
}

// ===== NOTIFICATIONS =====
function renderNotifications() {
  const container = document.getElementById('notifContainer');
  if (!allNotifications || allNotifications.length === 0) {
    container.innerHTML = `<div class="empty-state"><div class="emoji">🔔</div><p>Пока уведомлений нет</p></div>`;
    return;
  }
  container.innerHTML = allNotifications.map(n => `
    <div class="notif-item">
      <div class="notif-icon">🔔</div>
      <div>
        <div class="notif-text">${n.html}</div>
        <div class="notif-time">${formatTime(n.time)}</div>
      </div>
    </div>
  `).join('');
}

// ===== IMAGE MODAL =====
function openImgModal(src) {
  document.getElementById('imgModalSrc').src = src;
  document.getElementById('imgModal').classList.add('show');
}

function closeImgModal() {
  document.getElementById('imgModal').classList.remove('show');
  document.getElementById('imgModalSrc').src = '';
}

// ===== UTILS =====
function formatTime(ts) {
  const diff = Date.now() - ts;
  const sec = Math.floor(diff / 1000);
  if (sec < 60) return 'только что';
  const min = Math.floor(sec / 60);
  if (min < 60) return min + ' мин назад';
  const hr = Math.floor(min / 60);
  if (hr < 24) return hr + ' ч назад';
  const d = Math.floor(hr / 24);
  return d + ' д назад';
}

function escapeHtml(str) {
  if (!str) return '';
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function escapeAttr(str) {
  if (!str) return '';
  return str.replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

// ===== INIT =====
document.addEventListener('DOMContentLoaded', () => {
  loadAll();

  // Check session
  const savedSession = sessionStorage.getItem('vibe_session');
  if (savedSession && allUsers[savedSession]) {
    currentUser = allUsers[savedSession];
    startApp();
  }

  // Enter key for auth
  document.getElementById('loginPass').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
  document.getElementById('regPass2').addEventListener('keydown', e => { if (e.key === 'Enter') doRegister(); });
});
</script>

