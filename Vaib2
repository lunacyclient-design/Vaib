<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Вайб — социальная сеть</title>
<script src="https://cdn.jsdelivr.net/npm/mqtt@5.10.1/dist/mqtt.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap');

  :root {
    --bg: #f8f9ff;
    --white: #ffffff;
    --blue: #3b82f6;
    --blue-light: #eff6ff;
    --blue-dark: #1d4ed8;
    --gray: #6b7280;
    --gray-light: #f3f4f6;
    --border: #e5e7eb;
    --text: #111827;
    --text-soft: #6b7280;
    --shadow: 0 2px 12px rgba(59,130,246,0.08);
    --shadow-md: 0 4px 24px rgba(59,130,246,0.14);
    --radius: 16px;
    --radius-sm: 10px;
    --transition: all 0.22s cubic-bezier(.4,0,.2,1);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ——— AUTH SCREEN ——— */
  #authScreen {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background: linear-gradient(135deg, #eff6ff 0%, #f8f9ff 60%, #e0f2fe 100%);
  }

  .auth-card {
    background: var(--white);
    border-radius: 24px;
    box-shadow: var(--shadow-md);
    padding: 40px 36px;
    width: 100%;
    max-width: 420px;
    animation: fadeUp 0.4s ease;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .auth-logo {
    font-size: 28px;
    font-weight: 800;
    color: var(--blue);
    text-align: center;
    margin-bottom: 6px;
    letter-spacing: -0.5px;
  }

  .auth-sub {
    text-align: center;
    color: var(--text-soft);
    font-size: 14px;
    margin-bottom: 28px;
  }

  .auth-tabs {
    display: flex;
    background: var(--gray-light);
    border-radius: var(--radius-sm);
    padding: 4px;
    margin-bottom: 24px;
    gap: 4px;
  }

  .auth-tab {
    flex: 1;
    padding: 9px;
    border: none;
    background: transparent;
    border-radius: 7px;
    cursor: pointer;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: var(--text-soft);
    transition: var(--transition);
  }

  .auth-tab.active {
    background: var(--white);
    color: var(--blue);
    box-shadow: 0 1px 6px rgba(0,0,0,0.08);
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-soft);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-group input, .form-group textarea {
    width: 100%;
    padding: 12px 14px;
    border: 2px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: 'Nunito', sans-serif;
    font-size: 15px;
    color: var(--text);
    background: var(--white);
    transition: var(--transition);
    outline: none;
    resize: none;
  }

  .form-group input:focus, .form-group textarea:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
  }

  .btn-primary {
    width: 100%;
    padding: 13px;
    background: var(--blue);
    color: white;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 16px;
    cursor: pointer;
    transition: var(--transition);
    letter-spacing: 0.3px;
  }

  .btn-primary:hover {
    background: var(--blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(59,130,246,0.3);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .auth-error {
    color: #ef4444;
    font-size: 13px;
    text-align: center;
    margin-top: 10px;
    min-height: 18px;
  }

  /* ——— APP LAYOUT ——— */
  #appScreen { display: none; min-height: 100vh; }

  /* ——— TOPBAR ——— */
  .topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 60px;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 20px;
    z-index: 200;
    gap: 16px;
  }

  .burger-btn {
    width: 40px; height: 40px;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    transition: var(--transition);
    flex-shrink: 0;
  }

  .burger-btn:hover { background: var(--blue-light); }
  .burger-btn.active { background: var(--blue-light); }

  .burger-btn span {
    display: block;
    width: 20px; height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: var(--transition);
  }

  .burger-btn.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); background: var(--blue); }
  .burger-btn.active span:nth-child(2) { opacity: 0; }
  .burger-btn.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); background: var(--blue); }

  .topbar-logo {
    font-size: 20px;
    font-weight: 800;
    color: var(--blue);
    flex: 1;
    letter-spacing: -0.5px;
  }

  .topbar-actions {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .icon-btn {
    width: 38px; height: 38px;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: var(--transition);
    position: relative;
    color: var(--text);
  }

  .icon-btn:hover { background: var(--blue-light); color: var(--blue); }
  .icon-btn.active { background: var(--blue-light); color: var(--blue); }

  .notif-badge {
    position: absolute;
    top: 4px; right: 4px;
    width: 8px; height: 8px;
    background: #ef4444;
    border-radius: 50%;
    border: 2px solid white;
    display: none;
  }

  .notif-badge.show { display: block; }

  .avatar-btn {
    width: 34px; height: 34px;
    border-radius: 50%;
    border: 2px solid var(--border);
    cursor: pointer;
    overflow: hidden;
    transition: var(--transition);
    background: var(--blue-light);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; color: var(--blue); font-size: 14px;
    flex-shrink: 0;
  }

  .avatar-btn:hover { border-color: var(--blue); }

  .avatar-btn img {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  /* ——— SIDEBAR ——— */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.18);
    z-index: 299;
    backdrop-filter: blur(2px);
  }

  .sidebar-overlay.show { display: block; }

  .sidebar {
    position: fixed;
    top: 0; left: -280px;
    width: 260px;
    height: 100vh;
    background: var(--white);
    box-shadow: var(--shadow-md);
    z-index: 300;
    transition: left 0.3s cubic-bezier(.4,0,.2,1);
    display: flex;
    flex-direction: column;
    padding: 70px 0 20px;
  }

  .sidebar.open { left: 0; }

  .sidebar-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 24px;
    cursor: pointer;
    transition: var(--transition);
    font-weight: 700;
    font-size: 15px;
    color: var(--text);
    border-left: 3px solid transparent;
  }

  .sidebar-item:hover {
    background: var(--blue-light);
    color: var(--blue);
    border-left-color: var(--blue);
  }

  .sidebar-item.active {
    background: var(--blue-light);
    color: var(--blue);
    border-left-color: var(--blue);
  }

  .sidebar-icon { font-size: 20px; }

  .sidebar-divider {
    height: 1px;
    background: var(--border);
    margin: 12px 0;
  }

  .sidebar-logout {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 24px;
    cursor: pointer;
    transition: var(--transition);
    font-weight: 700;
    font-size: 15px;
    color: #ef4444;
  }

  .sidebar-logout:hover { background: #fef2f2; }

  /* ——— MAIN CONTENT ——— */
  .main-content {
    padding-top: 60px;
    max-width: 680px;
    margin: 0 auto;
    padding-left: 16px;
    padding-right: 16px;
  }

  /* ——— PANELS ——— */
  .panel { display: none; padding: 20px 0 80px; animation: fadeUp 0.25s ease; }
  .panel.active { display: block; }

  /* ——— CREATE POST ——— */
  .create-post-card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 20px;
    margin-bottom: 20px;
    border: 1px solid var(--border);
  }

  .create-post-header {
    display: flex;
    gap: 12px;
    margin-bottom: 14px;
  }

  .create-post-textarea {
    width: 100%;
    border: none;
    resize: none;
    font-family: 'Nunito', sans-serif;
    font-size: 15px;
    color: var(--text);
    outline: none;
    min-height: 70px;
    background: transparent;
    line-height: 1.6;
  }

  .create-post-textarea::placeholder { color: #9ca3af; }

  .create-post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }

  .image-preview-wrap {
    margin: 10px 0;
    position: relative;
    display: none;
  }

  .image-preview-wrap.show { display: block; }

  .image-preview-wrap img {
    max-width: 100%;
    max-height: 300px;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  .remove-img-btn {
    position: absolute;
    top: 6px; right: 6px;
    background: rgba(0,0,0,0.5);
    color: white;
    border: none;
    border-radius: 50%;
    width: 26px; height: 26px;
    cursor: pointer;
    font-size: 14px;
    display: flex; align-items: center; justify-content: center;
  }

  .attach-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 22px;
    color: var(--text-soft);
    transition: var(--transition);
    padding: 4px 8px;
    border-radius: 8px;
  }

  .attach-btn:hover { color: var(--blue); background: var(--blue-light); }

  .post-submit-btn {
    padding: 9px 22px;
    background: var(--blue);
    color: white;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 14px;
    cursor: pointer;
    transition: var(--transition);
  }

  .post-submit-btn:hover {
    background: var(--blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(59,130,246,0.3);
  }

  .post-submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* ——— POST CARD ——— */
  .post-card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    margin-bottom: 16px;
    overflow: hidden;
    animation: fadeUp 0.3s ease;
  }

  .post-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px 12px;
  }

  .post-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--blue-light);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; color: var(--blue); font-size: 15px;
    cursor: pointer;
    transition: var(--transition);
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid var(--border);
  }

  .post-avatar:hover { border-color: var(--blue); }

  .post-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .post-meta { flex: 1; }

  .post-username {
    font-weight: 800;
    font-size: 14px;
    cursor: pointer;
    transition: var(--transition);
  }

  .post-username:hover { color: var(--blue); }

  .post-time {
    font-size: 12px;
    color: var(--text-soft);
    margin-top: 1px;
  }

  .post-body {
    padding: 0 20px 14px;
  }

  .post-text {
    font-size: 15px;
    line-height: 1.65;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .post-image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    display: block;
    margin-top: 12px;
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .post-actions {
    display: flex;
    gap: 4px;
    padding: 8px 16px 12px;
    border-top: 1px solid var(--border);
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border: none;
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--text-soft);
    transition: var(--transition);
  }

  .action-btn:hover { background: var(--blue-light); color: var(--blue); }

  .action-btn.liked { color: #ef4444; }
  .action-btn.liked:hover { background: #fef2f2; color: #dc2626; }

  .action-btn .icon { font-size: 17px; }

  /* ——— COMMENTS ——— */
  .comments-section {
    padding: 0 20px 16px;
    display: none;
  }

  .comments-section.show { display: block; }

  .comment-input-row {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
    align-items: center;
  }

  .comment-input {
    flex: 1;
    padding: 9px 14px;
    border: 2px solid var(--border);
    border-radius: 20px;
    font-family: 'Nunito', sans-serif;
    font-size: 14px;
    outline: none;
    transition: var(--transition);
    background: var(--bg);
  }

  .comment-input:focus {
    border-color: var(--blue);
    background: white;
  }

  .comment-send-btn {
    width: 34px; height: 34px;
    background: var(--blue);
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 15px;
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition);
    flex-shrink: 0;
  }

  .comment-send-btn:hover {
    background: var(--blue-dark);
    transform: scale(1.08);
  }

  .comment-item {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
    animation: fadeUp 0.2s ease;
  }

  .comment-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--blue-light);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 11px; color: var(--blue);
    flex-shrink: 0;
    overflow: hidden;
    border: 1.5px solid var(--border);
  }

  .comment-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .comment-bubble {
    background: var(--gray-light);
    border-radius: 14px;
    padding: 8px 12px;
    flex: 1;
    min-width: 0;
  }

  .comment-bubble strong {
    font-size: 13px;
    color: var(--text);
    cursor: pointer;
  }

  .comment-bubble strong:hover { color: var(--blue); }

  .comment-bubble p {
    font-size: 13px;
    margin-top: 2px;
    color: var(--text);
    word-break: break-word;
  }

  /* ——— PROFILE VIEW ——— */
  .profile-view { animation: fadeUp 0.25s ease; padding-bottom: 80px; }

  .profile-banner {
    height: 140px;
    background: linear-gradient(135deg, #3b82f6, #06b6d4);
    border-radius: 0 0 0 0;
    position: relative;
  }

  .profile-info-card {
    background: var(--white);
    border-radius: 0 0 var(--radius) var(--radius);
    padding: 0 20px 20px;
    border: 1px solid var(--border);
    border-top: none;
    margin-bottom: 16px;
  }

  .profile-avatar-wrap {
    margin-top: -44px;
    margin-bottom: 12px;
    position: relative;
    width: fit-content;
  }

  .profile-big-avatar {
    width: 88px; height: 88px;
    border-radius: 50%;
    border: 4px solid white;
    background: var(--blue-light);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 28px; color: var(--blue);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .profile-big-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .profile-name {
    font-size: 20px;
    font-weight: 800;
  }

  .profile-handle {
    font-size: 14px;
    color: var(--text-soft);
    margin-bottom: 8px;
  }

  .profile-bio {
    font-size: 14px;
    color: var(--text);
    margin-bottom: 14px;
    line-height: 1.6;
  }

  .profile-stats {
    display: flex;
    gap: 24px;
    margin-bottom: 16px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-num {
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
    display: block;
  }

  .stat-label {
    font-size: 12px;
    color: var(--text-soft);
    font-weight: 600;
  }

  .follow-btn {
    padding: 9px 24px;
    background: var(--blue);
    color: white;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 14px;
    cursor: pointer;
    transition: var(--transition);
  }

  .follow-btn:hover {
    background: var(--blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(59,130,246,0.3);
  }

  .follow-btn.following {
    background: white;
    color: var(--blue);
    border: 2px solid var(--blue);
  }

  .follow-btn.following:hover {
    background: #fef2f2;
    color: #ef4444;
    border-color: #ef4444;
  }

  /* ——— MY PROFILE PANEL ——— */
  .my-profile-card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    padding: 24px;
    margin-bottom: 20px;
  }

  .my-profile-header {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 20px;
  }

  .my-avatar-edit {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: var(--blue-light);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 22px; color: var(--blue);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    border: 3px solid var(--border);
    transition: var(--transition);
    flex-shrink: 0;
  }

  .my-avatar-edit:hover { border-color: var(--blue); }

  .my-avatar-edit img { width: 100%; height: 100%; object-fit: cover; }

  .my-avatar-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: var(--transition);
    color: white;
    font-size: 20px;
  }

  .my-avatar-edit:hover .my-avatar-overlay { opacity: 1; }

  .section-title {
    font-size: 16px;
    font-weight: 800;
    margin-bottom: 14px;
    color: var(--text);
  }

  .btn-save {
    padding: 10px 24px;
    background: var(--blue);
    color: white;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 14px;
    cursor: pointer;
    transition: var(--transition);
    margin-top: 4px;
  }

  .btn-save:hover {
    background: var(--blue-dark);
    transform: translateY(-1px);
  }

  /* ——— NOTIFICATIONS ——— */
  .notif-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.2s ease;
  }

  .notif-icon {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--blue-light);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .notif-text { font-size: 14px; line-height: 1.5; }
  .notif-text strong { color: var(--blue); }
  .notif-time { font-size: 12px; color: var(--text-soft); margin-top: 3px; }

  /* ——— MESSAGES ——— */
  .msg-panel-header {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 16px;
    padding-top: 20px;
  }

  .msg-coming-soon {
    background: var(--white);
    border-radius: var(--radius);
    padding: 40px 24px;
    text-align: center;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }

  .msg-coming-soon .big-emoji { font-size: 48px; margin-bottom: 12px; }
  .msg-coming-soon p { color: var(--text-soft); font-size: 15px; }

  .conn-status { display: none !important; }

  /* ——— IMAGE MODAL ——— */
  .img-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    align-items: center;
